<% content_for :title, @course.name %>

<%= link_to "→ #{t('courses.back_to_courses')}", courses_path, class: ui_class(:button, :link, :small) %>

<h1 class="<%= ui_class(:title) %>"><%= icon("course") %> <%= @course.name %></h1>
<% if @course.image.attached? %>
  <%= image_tag @course.image, class: "course-image mb-3", style: "max-height:260px" %>
<% end %>
<p class="transcript"><%= @course.details %></p>

<div class="mt-4">
  <% if @episodes.any? %>
    <table class="<%= ui_class(:table) %>" data-controller="datatable">
      <thead>
        <tr>
          <th><%= t("episodes.kind_col") %></th>
          <th><%= t("episodes.title_col") %></th>
        </tr>
      </thead>
      <tbody>
        <% @episodes.each do |episode| %>
          <tr>
            <td><span class="<%= ui_class(:badge, episode.quiz? ? :warning : :info) %>"><%= t("episodes.kind.#{episode.kind}") %></span></td>
            <td><%= link_to episode.display_title, course_episode_path(@course, episode) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
