<div dir="rtl" lang="he" style="text-align: right; font-family: Arial, sans-serif;">
  <h1><%= t("invitation.email_greeting", name: @user.display_name) %></h1>
  <p><%= t("invitation.email_body") %></p>
  <p>
    <%= link_to t("invitation.email_cta"), @url,
          style: "display:inline-block;padding:12px 20px;background:#4f46e5;color:#fff;border-radius:6px;text-decoration:none;" %>
  </p>
  <p style="color:#666;font-size:13px;"><%= t("invitation.email_expiry") %></p>
</div>
