<% content_for :title, t("snippets.title") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= icon("snippets") %> <%= t("snippets.title") %></h1>
  <%= link_to t("snippets.new"), new_snippet_path, class: ui_class(:button, :primary) %>
</div>

<% if @snippets.empty? %>
  <div class="<%= ui_class(:alert, :notice) %>"><%= t("snippets.empty") %></div>
<% else %>
  <%= render "snippets/table", snippets: @snippets %>
<% end %>
