<% content_for :title, t("admin.episodes.edit_title") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= @episode.display_title %></h1>
  <%= link_to t("admin.studio.open"), admin_course_episode_studio_path(@course, @episode), class: ui_class(:button, :primary) %>
</div>

<%= render "form", course: @course, episode: @episode %>

<hr>
<section>
  <h2 class="<%= ui_class(:subtitle) %>"><%= t("admin.episodes.ai_section") %></h2>
  <div class="actions">
    <%= button_to t("admin.episodes.generate_content"), generate_content_admin_course_episode_path(@course, @episode), class: ui_class(:button, :secondary) %>
    <%= button_to t("admin.episodes.generate_audio"), generate_audio_admin_course_episode_path(@course, @episode), class: ui_class(:button, :secondary) %>
  </div>
  <% if @episode.audio.attached? %>
    <audio controls class="mt-2 w-100"><source src="<%= url_for(@episode.audio) %>"></audio>
  <% end %>
</section>

<hr>
<section>
  <h2 class="<%= ui_class(:subtitle) %>"><%= t("admin.docs.title") %></h2>
  <% @episode.markdown_docs.order(:name).each do |doc| %>
    <div class="<%= ui_class(:card) %> mb-2"><div class="<%= ui_class(:card_body) %> d-flex justify-content-between align-items-center">
      <span><%= doc.name %></span>
      <%= button_to t("admin.docs.deleted"), admin_course_episode_markdown_doc_path(@course, @episode, doc), method: :delete, class: ui_class(:button, :danger, :small) %>
    </div></div>
  <% end %>
  <%= form_with url: admin_course_episode_markdown_docs_path(@course, @episode), scope: :markdown_doc do |f| %>
    <div class="<%= ui_class(:field) %>">
      <%= f.label :name, t("admin.docs.name"), class: ui_class(:label) %>
      <%= f.text_field :name, class: ui_class(:input) %>
    </div>
    <div class="<%= ui_class(:field) %>">
      <%= f.label :content, t("admin.docs.content"), class: ui_class(:label) %>
      <%= f.text_area :content, rows: 4, class: ui_class(:textarea) %>
    </div>
    <%= f.submit t("admin.docs.add"), class: ui_class(:button, :secondary) %>
  <% end %>
</section>

<hr>
<section>
  <h2 class="<%= ui_class(:subtitle) %>"><%= t("admin.quiz.title") %></h2>
  <% @episode.quiz_questions.each do |q| %>
    <div class="<%= ui_class(:card) %> mb-2"><div class="<%= ui_class(:card_body) %> d-flex justify-content-between align-items-center">
      <span><%= q.prompt %></span>
      <%= button_to t("admin.quiz.deleted"), admin_course_episode_quiz_question_path(@course, @episode, q), method: :delete, class: ui_class(:button, :danger, :small) %>
    </div></div>
  <% end %>
  <%= form_with url: admin_course_episode_quiz_questions_path(@course, @episode), scope: :quiz_question do |f| %>
    <div class="<%= ui_class(:field) %>">
      <%= f.label :prompt, t("admin.quiz.prompt"), class: ui_class(:label) %>
      <%= f.text_area :prompt, rows: 2, class: ui_class(:textarea) %>
    </div>
    <div class="<%= ui_class(:field) %>">
      <%= f.label :choices, t("admin.quiz.choices"), class: ui_class(:label) %>
      <%= f.text_area :choices, rows: 3, class: ui_class(:textarea) %>
    </div>
    <div class="<%= ui_class(:field) %>">
      <%= f.label :correct_choice, t("admin.quiz.correct"), class: ui_class(:label) %>
      <%= f.text_field :correct_choice, class: ui_class(:input) %>
    </div>
    <%= f.submit t("admin.quiz.add"), class: ui_class(:button, :secondary) %>
  <% end %>
</section>
