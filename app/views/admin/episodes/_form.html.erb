<%= form_with model: [:admin, course, episode] do |f| %>
  <% if episode.errors.any? %>
    <div class="<%= ui_class(:alert, :alert) %>"><%= episode.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :title, t("admin.episodes.episode_title"), class: ui_class(:label) %>
    <%= f.text_field :title, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :name, t("admin.episodes.name"), class: ui_class(:label) %>
    <%= f.text_field :name, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :kind, t("admin.episodes.kind"), class: ui_class(:label) %>
    <% kinds = Episode.kinds.keys.map { |k| [t("episodes.kind.#{k}"), k] } %>
    <% if css_framework == :bulma %>
      <div class="select is-fullwidth"><%= f.select :kind, kinds %></div>
    <% else %>
      <%= f.select :kind, kinds, {}, class: ui_class(:select) %>
    <% end %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :position, t("admin.episodes.position"), class: ui_class(:label) %>
    <%= f.number_field :position, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :transcript, t("admin.episodes.transcript"), class: ui_class(:label) %>
    <%= f.text_area :transcript, rows: 6, class: ui_class(:textarea) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :movie_url, t("admin.episodes.movie_url"), class: ui_class(:label) %>
    <%= f.text_field :movie_url, class: ui_class(:input), dir: "ltr" %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :audiobook_url, t("admin.episodes.audiobook_url"), class: ui_class(:label) %>
    <%= f.text_field :audiobook_url, class: ui_class(:input), dir: "ltr" %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :movie, t("admin.episodes.movie_file"), class: ui_class(:label) %>
    <%= f.file_field :movie, accept: "video/*", class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :audio, t("admin.episodes.audio_file"), class: ui_class(:label) %>
    <%= f.file_field :audio, accept: "audio/*", class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :thumbnail, t("admin.episodes.thumbnail"), class: ui_class(:label) %>
    <%= f.file_field :thumbnail, accept: "image/*", class: ui_class(:input) %>
  </div>

  <%= f.submit t("admin.episodes.save"), class: ui_class(:button, :primary) %>
<% end %>
