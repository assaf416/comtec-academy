<% content_for :title, t("admin.users.title") %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= icon("users") %> <%= t("admin.users.title") %></h1>
  <%= link_to t("admin.users.invite"), new_admin_user_path, class: ui_class(:button, :primary) %>
</div>

<table class="<%= ui_class(:table) %>" data-controller="datatable">
  <thead>
    <tr>
      <th><%= t("admin.users.email_address") %></th>
      <th><%= t("admin.users.name") %></th>
      <th><%= t("admin.users.role") %></th>
      <th><%= t("admin.users.status") %></th>
      <th class="no-sort"><%= t("admin.users.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email_address %></td>
        <td><%= user.name %></td>
        <td><span class="<%= ui_class(:badge, user.admin? ? :info : :muted) %>"><%= t("admin.users.roles.#{user.role}") %></span></td>
        <td><span class="<%= ui_class(:badge, user.active? ? :success : :warning) %>"><%= t("admin.users.statuses.#{user.status}") %></span></td>
        <td class="no-sort">
          <% acts = [ { label: t("admin.users.edit"), icon: :edit, path: edit_admin_user_path(user) } ] %>
          <% acts << { label: t("admin.users.resend"), icon: :resend, path: resend_invitation_admin_user_path(user), method: :post } if user.invited? %>
          <% acts << { label: t("admin.users.delete"), icon: :delete, path: admin_user_path(user), method: :delete, confirm: "?" } %>
          <%= render "shared/row_actions", actions: acts %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
