<% content_for :title, @course.name %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= icon("course") %> <%= @course.name %></h1>
  <div class="actions">
    <%= link_to t("admin.courses.edit"), edit_admin_course_path(@course), class: ui_class(:button, :secondary, :small) %>
    <%= link_to t("admin.courses.add_episode"), new_admin_course_episode_path(@course), class: ui_class(:button, :primary, :small) %>
  </div>
</div>

<table class="<%= ui_class(:table) %>" data-controller="datatable">
  <thead>
    <tr>
      <th><%= t("admin.episodes.position") %></th>
      <th><%= t("admin.episodes.episode_title") %></th>
      <th><%= t("admin.episodes.kind") %></th>
      <th class="no-sort"><%= t("shared.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @episodes.each do |episode| %>
      <tr>
        <td><%= episode.position %></td>
        <td><%= episode.display_title %></td>
        <td><span class="<%= ui_class(:badge, episode.quiz? ? :warning : :info) %>"><%= t("episodes.kind.#{episode.kind}") %></span></td>
        <td class="no-sort">
          <%= render "shared/row_actions", actions: [
            { label: t("admin.courses.edit"), icon: :edit, path: edit_admin_course_episode_path(@course, episode) },
            { label: t("admin.studio.open"), icon: :studio, path: admin_course_episode_studio_path(@course, episode) }
          ] %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
