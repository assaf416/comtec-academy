<% content_for :title, t("admin.courses.title") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= icon("courses") %> <%= t("admin.courses.title") %></h1>
  <%= link_to t("admin.courses.new"), new_admin_course_path, class: ui_class(:button, :primary) %>
</div>

<table class="<%= ui_class(:table) %>" data-controller="datatable">
  <thead>
    <tr>
      <th><%= t("admin.courses.name") %></th>
      <th><%= t("admin.courses.published") %></th>
      <th><%= t("admin.courses.episodes") %></th>
      <th class="no-sort"><%= t("shared.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @courses.each do |course| %>
      <tr>
        <td><%= link_to course.name, admin_course_path(course) %></td>
        <td><span class="<%= ui_class(:badge, course.published? ? :success : :muted) %>"><%= course.published? ? "✓" : "—" %></span></td>
        <td><%= course.episodes.size %></td>
        <td class="no-sort">
          <%= render "shared/row_actions", actions: [
            { label: t("admin.courses.edit"), icon: :edit, path: edit_admin_course_path(course) },
            { label: t("admin.courses.delete"), icon: :delete, path: admin_course_path(course), method: :delete, confirm: "?" }
          ] %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
