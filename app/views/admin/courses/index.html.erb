<% content_for :title, t("admin.courses.title") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= t("admin.courses.title") %></h1>
  <%= link_to t("admin.courses.new"), new_admin_course_path, class: ui_class(:button, :primary) %>
</div>

<table class="<%= ui_class(:table) %>">
  <thead>
    <tr>
      <th><%= t("admin.courses.name") %></th>
      <th><%= t("admin.courses.published") %></th>
      <th><%= t("admin.courses.episodes") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @courses.each do |course| %>
      <tr>
        <td><%= link_to course.name, admin_course_path(course) %></td>
        <td><span class="<%= ui_class(:badge, course.published? ? :success : :muted) %>"><%= course.published? ? "✓" : "—" %></span></td>
        <td><%= course.episodes.size %></td>
        <td>
          <%= link_to t("admin.courses.edit"), edit_admin_course_path(course), class: ui_class(:button, :secondary, :small) %>
          <%= button_to t("admin.courses.delete"), admin_course_path(course), method: :delete,
                data: { turbo_confirm: "?" }, class: ui_class(:button, :danger, :small) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
