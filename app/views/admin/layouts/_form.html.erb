<%= form_with model: [:admin, layout] do |f| %>
  <% if layout.errors.any? %>
    <div class="<%= ui_class(:alert, :alert) %>"><%= layout.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :key, t("admin.layouts.key"), class: ui_class(:label) %>
    <%= f.text_field :key, class: ui_class(:input), dir: "ltr" %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= f.label :name, t("admin.layouts.name"), class: ui_class(:label) %>
    <%= f.text_field :name, class: ui_class(:input) %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= f.label :direction, t("admin.layouts.direction"), class: ui_class(:label) %>
    <% if css_framework == :bulma %>
      <div class="select is-fullwidth"><%= f.select :direction, %w[rtl ltr] %></div>
    <% else %>
      <%= f.select :direction, %w[rtl ltr], {}, class: ui_class(:select) %>
    <% end %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= f.label :kind, t("admin.layouts.kind"), class: ui_class(:label) %>
    <% kinds = Layout.kinds.keys %>
    <% if css_framework == :bulma %>
      <div class="select is-fullwidth"><%= f.select :kind, kinds %></div>
    <% else %>
      <%= f.select :kind, kinds, {}, class: ui_class(:select) %>
    <% end %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= f.label :description, t("admin.layouts.description"), class: ui_class(:label) %>
    <%= f.text_field :description, class: ui_class(:input) %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= f.label :css, t("admin.layouts.css"), class: ui_class(:label) %>
    <%= f.text_area :css, rows: 6, class: ui_class(:textarea), dir: "ltr", style: "font-family:monospace" %>
  </div>

  <%= f.submit t("admin.layouts.save"), class: ui_class(:button, :primary) %>
<% end %>
