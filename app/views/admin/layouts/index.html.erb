<% content_for :title, t("admin.layouts.title") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="<%= ui_class(:title) %> mb-0"><%= icon("layouts") %> <%= t("admin.layouts.title") %></h1>
  <%= link_to t("admin.layouts.new"), new_admin_layout_path, class: ui_class(:button, :primary) %>
</div>

<table class="<%= ui_class(:table) %>" data-controller="datatable">
  <thead>
    <tr>
      <th><%= t("admin.layouts.key") %></th>
      <th><%= t("admin.layouts.name") %></th>
      <th><%= t("admin.layouts.direction") %></th>
      <th><%= t("admin.layouts.kind") %></th>
      <th class="no-sort"><%= t("shared.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @layouts.each do |layout| %>
      <tr>
        <td><code dir="ltr"><%= layout.key %></code></td>
        <td><%= layout.name %></td>
        <td><%= layout.direction %></td>
        <td><span class="<%= ui_class(:badge, :info) %>"><%= layout.kind %></span></td>
        <td class="no-sort">
          <%= render "shared/row_actions", actions: [
            { label: t("admin.layouts.edit"), icon: :edit, path: edit_admin_layout_path(layout) },
            { label: t("admin.layouts.delete"), icon: :delete, path: admin_layout_path(layout), method: :delete, confirm: "?" }
          ] %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
