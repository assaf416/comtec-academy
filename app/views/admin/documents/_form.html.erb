<%= form_with model: [:admin, project, document] do |f| %>
  <% if document.errors.any? %>
    <div class="<%= ui_class(:alert, :alert) %>"><%= document.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :doc_type, t("admin.documents.type"), class: ui_class(:label) %>
    <% if document.new_record? %>
      <% types = Document.doc_types.keys.map { |k| [t("documents.types.#{k}"), k] } %>
      <% if css_framework == :bulma %>
        <div class="select is-fullwidth"><%= f.select :doc_type, types %></div>
      <% else %>
        <%= f.select :doc_type, types, {}, class: ui_class(:select) %>
      <% end %>
    <% else %>
      <p><span class="<%= ui_class(:badge, :info) %>"><%= t("documents.types.#{document.doc_type}") %></span></p>
    <% end %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :title, t("admin.documents.title"), class: ui_class(:label) %>
    <%= f.text_field :title, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :tags, t("admin.documents.tags"), class: ui_class(:label) %>
    <%= f.text_field :tags, class: ui_class(:input), placeholder: t("admin.documents.tags_hint") %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :content, t("admin.documents.content"), class: ui_class(:label) %>
    <%= f.text_area :content, rows: 16, class: ui_class(:textarea), dir: "auto", style: "font-family:monospace" %>
  </div>

  <%= f.submit t("admin.documents.save"), class: ui_class(:button, :primary) %>
<% end %>
