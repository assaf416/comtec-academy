<%= form_with model: [:admin, presentation] do |f| %>
  <% if presentation.errors.any? %>
    <div class="<%= ui_class(:alert, :alert) %>"><%= presentation.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :title, t("admin.presentations.title_label"), class: ui_class(:label) %>
    <%= f.text_field :title, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :description, t("admin.presentations.description"), class: ui_class(:label) %>
    <%= f.text_field :description, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :source_md, t("admin.presentations.screenplay"), class: ui_class(:label) %>
    <%= f.text_area :source_md, rows: 16, class: ui_class(:textarea), dir: "auto", style: "font-family:monospace" %>
    <p class="text-muted"><small><%= t("admin.presentations.screenplay_hint") %></small></p>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :background_music, t("admin.presentations.background_music"), class: ui_class(:label) %>
    <%= f.file_field :background_music, accept: "audio/*", class: ui_class(:input) %>
  </div>

  <%= f.submit t("admin.presentations.save"), class: ui_class(:button, :primary) %>
<% end %>
