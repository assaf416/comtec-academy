<%= form_with model: [:admin, project] do |f| %>
  <% if project.errors.any? %>
    <div class="<%= ui_class(:alert, :alert) %>"><%= project.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :name, t("admin.projects.name"), class: ui_class(:label) %>
    <%= f.text_field :name, class: ui_class(:input) %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :slug, t("admin.projects.slug"), class: ui_class(:label) %>
    <%= f.text_field :slug, class: ui_class(:input), dir: "ltr", placeholder: "auto from name" %>
  </div>

  <div class="<%= ui_class(:field) %>">
    <%= f.label :description, t("admin.projects.description"), class: ui_class(:label) %>
    <%= f.text_area :description, rows: 3, class: ui_class(:textarea) %>
  </div>

  <%= f.submit t("admin.projects.save"), class: ui_class(:button, :primary) %>
<% end %>
