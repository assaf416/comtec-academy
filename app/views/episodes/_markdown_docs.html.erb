<section class="mt-4">
  <h2 class="<%= ui_class(:subtitle) %>"><%= t("documents.title") %></h2>
  <% docs.each do |doc| %>
    <div class="<%= ui_class(:card) %> mb-2">
      <div class="<%= ui_class(:card_body) %>">
        <h3 class="<%= ui_class(:card_title) %>"><%= doc.name %></h3>
        <div class="markdown-body"><%= doc.to_html %></div>
      </div>
    </div>
  <% end %>
</section>
