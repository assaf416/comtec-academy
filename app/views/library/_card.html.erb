<div class="<%= ui_class(:grid_item) %>">
  <div class="<%= ui_class(:card) %>">
    <div class="<%= ui_class(:card_body) %>">
      <h3 class="<%= ui_class(:card_title) %>">
        <% if document.html_original? %>
          <%= link_to document.display_title, raw_document_path(document), target: "_blank", rel: "noopener" %>
        <% else %>
          <%= link_to document.display_title, document_path(document) %>
        <% end %>
      </h3>
      <p>
        <% if document.project %>
          <span class="<%= ui_class(:badge, :info) %>"><%= document.project.name %></span>
        <% else %>
          <span class="<%= ui_class(:badge, :muted) %>"><%= t("library.standalone") %></span>
        <% end %>
        <span class="<%= ui_class(:badge, :muted) %>"><%= t("library.views", count: document.views_count) %></span>
      </p>
      <% if document.favorited_by?(current_user) %>
        <%= button_to "♥ #{t('document_view.unfavorite')}", document_favorite_path(document),
              method: :delete, class: ui_class(:button, :secondary, :small) %>
      <% else %>
        <%= button_to "♡ #{t('document_view.favorite')}", document_favorite_path(document),
              method: :post, class: ui_class(:button, :secondary, :small) %>
      <% end %>
    </div>
  </div>
</div>
